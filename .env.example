# --- Local development (copy to `.env.local`) ---
DB_FILE_NAME=contacts.db
# Optional: SEED_FORCE=1 replaces seeded rows when running db:seed locally

# --- Production (Turso via Vercel Storage — auto-injected when linked) ---
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token
